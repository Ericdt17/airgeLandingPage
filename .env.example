# Checkout offre (#tarifs) — si absent : dev → http://localhost:5173/app/checkout, prod → https://app.video-story.com/app/checkout
# VITE_CHECKOUT_URL=http://localhost:5173/app/checkout

# CTA WhatsApp (pages marketing, ex. Courses particuliers) — URL complète wa.me ; si absent, repli sur le lien marketing par défaut
# VITE_WHATSAPP_WA_ME=https://wa.me/2376XXXXXXXX

# Waitlist (ComingSoonModal) — JSON POST
VITE_API_BASE_URL=https://your-api.onrender.com

# Recruitment (src/services/recruitmentApi.js) — si absent, repli : http://localhost:3000
VITE_API_URL=https://your-api.onrender.com

# POST /recruitment/apply — noms de champs multipart (optionnel, défauts ci-dessous)
# VITE_RECRUITMENT_PHOTO_FIELD=photo
# VITE_RECRUITMENT_CV_FIELD=cv
# VITE_RECRUITMENT_COVER_LETTER_FIELD=cover_letter
# VITE_RECRUITMENT_JOB_ID_FIELD=job_offer_id
